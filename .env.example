# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values.
# .env is excluded from git. This file is safe to commit.
# =============================================================================

# Environment: "development" (local) or "production" (Contabo server)
APP_ENV=development

# =============================================================================
# DATABASE
# =============================================================================
# LOCAL DEVELOPMENT -- use a separate database to keep dev data isolated
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/job_agent_dev

# PRODUCTION (Contabo) -- uncomment and set for production server
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/job_agent

# =============================================================================
# OPENROUTER API  (https://openrouter.ai/keys)
# =============================================================================
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model to use -- choose based on environment:
#
#   LOCAL (cheap, fast for testing):
#     openai/gpt-3.5-turbo
#     meta-llama/llama-3-8b-instruct:free
#
#   PRODUCTION (better quality for real scraping):
#     openai/gpt-4-turbo
#     anthropic/claude-3.5-sonnet
#     openai/gpt-4o
#
OPENROUTER_MODEL=openai/gpt-3.5-turbo

# =============================================================================
# SCHEDULER
# =============================================================================
DAILY_RUN_TIME=08:00
TZ=UTC

# =============================================================================
# SCRAPING SCALE
# =============================================================================
# LOCAL -- small scale for testing workflows and sample data
MAX_JOBS_PER_RUN=50
MAX_COMPANIES_PER_RUN=20
MAX_CONTACTS_PER_COMPANY=5

# PRODUCTION -- uncomment for full-scale scraping on Contabo
# MAX_JOBS_PER_RUN=500
# MAX_COMPANIES_PER_RUN=200
# MAX_CONTACTS_PER_COMPANY=10

# =============================================================================
# EMAIL / SMTP (optional -- for digest emails and outreach)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# DIGEST_FROM_EMAIL=your@email.com
# DIGEST_TO_EMAIL=recipient@email.com
